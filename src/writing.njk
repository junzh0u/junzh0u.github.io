---
layout: base.njk
title: Jun Zhou — Writing
description: Essays and notes by Jun Zhou.
bodyClass: writing-page
---
<div class="name-block">
  <h1 class="name">Writing</h1>
  <p class="role">Essays and notes</p>
</div>

<h2 class="section-label">Posts</h2>
<section class="section-body">
{%- set posts = collections.writing | reverse %}
{%- if posts | length %}
  <ul class="uses-list">
  {%- for post in posts %}
    <li><a href="{{ post.url }}">{{ post.data.title }}</a> <span class="note">&mdash; <time datetime="{{ post.date | isoDate }}">{{ post.date | postDate }}</time></span></li>
  {%- endfor %}
  </ul>
{%- else %}
  <p>Nothing here yet.</p>
{%- endif %}
</section>
