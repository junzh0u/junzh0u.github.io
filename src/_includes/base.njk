<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {#- before the stylesheet: lets the browser paint the first frame's canvas
      dark for dark-mode users instead of flashing the default white while
      CSS is still loading #}
  <meta name="color-scheme" content="light dark">
  {#- the meta alone still races the external stylesheet in Chrome and can
      flash white between pages; this inline style paints the canvas in the
      final colors synchronously at parse time. Keep in sync with --bg in
      assets/css/style.css. #}
  {#- screen-only: in print the html background would paint the page below
      where the body's white ends (a tinted band at the bottom of the PDF) #}
  <style>
    @media screen {
      html { background-color: #faf6ef; }
    }
    @media screen and (prefers-color-scheme: dark) {
      html { background-color: #211c17; }
    }
  </style>

  <title>{{ title | safe }}</title>
  <meta name="description" content="{{ description | safe }}">
  <meta name="author" content="Jun Zhou">
  <link rel="canonical" href="https://junz.info{{ page.url }}">

  <meta property="og:title" content="{{ title | safe }}">
  <meta property="og:description" content="{{ description | safe }}">
  <meta property="og:url" content="https://junz.info{{ page.url }}">
  <meta property="og:site_name" content="Jun Zhou">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:image" content="https://junz.info/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title | safe }}">
  <meta name="twitter:image" content="https://junz.info/og-image.png">

  <link rel="icon" type="image/png" sizes="96x96" href="/assets/icons/favicon-96x96.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/assets/icons/site.webmanifest">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf6ef">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#211c17">

  <link rel="preload" href="/assets/fonts/Fraunces.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/Newsreader.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/PublicSans.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | bust }}">
  {%- block head %}{% endblock %}
</head>
<body class="{{ bodyClass }}">
  {%- block nav %}
  <nav class="page-nav">
    <a class="nav-home" href="/" aria-label="junz.info — home">junz<span>hou</span>.info</a>
    <ul class="nav-links">
      {#- actions come first so the site links keep the same position on every page #}
      {%- block navActions %}{% endblock %}
      <li><a href="/resume/"{% if page.url == '/resume/' %} aria-current="page"{% endif %}>R&eacute;sum&eacute;</a></li>
      <li><a href="/built/"{% if page.url == '/built/' %} aria-current="page"{% endif %}>Built</a></li>
      <li><a href="/writing/"{% if '/writing/' in page.url %} aria-current="page"{% endif %}>Writing</a></li>
      <li><a href="/uses/"{% if page.url == '/uses/' %} aria-current="page"{% endif %}>Uses</a></li>
      <li><a href="/now/"{% if page.url == '/now/' %} aria-current="page"{% endif %}>Now</a></li>
    </ul>
  </nav>
  {%- endblock %}

  <main class="page-grid">
{% block content %}{{ content | safe }}{% endblock %}
  </main>

{% block footer %}{% include "footer.njk" %}{% endblock %}
{% block scripts %}{% endblock %}
<!-- Cloudflare Web Analytics -->
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "99f6cfc20c8c480c9b8f31151dbea1fc"}'></script>
<!-- End Cloudflare Web Analytics -->
</body>
</html>
